{
  "consumer": {
    "name": "tester-web-frontend"
  },
  "interactions": [
    {
      "description": "uma requisição para adicionar produtos em lote no carrinho",
      "providerStates": [
        {
          "name": "usuário autenticado apto para adicionar itens no carrinho"
        }
      ],
      "request": {
        "body": {
          "products": [
            {
              "productId": 1,
              "quantity": 2
            },
            {
              "productId": 2,
              "quantity": 1
            }
          ]
        },
        "headers": {
          "Authorization": "Bearer pact-token",
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.products[0].productId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.products[0].quantity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.products[1].productId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.products[1].quantity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/cart"
      },
      "response": {
        "body": {
          "items": [
            {
              "id": 201,
              "product_id": 1,
              "quantity": 2,
              "user_id": 9002
            }
          ],
          "processed": 2
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.items[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.items[*].product_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.items[*].quantity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.items[*].user_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.processed": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "uma requisição para listar itens do carrinho",
      "providerStates": [
        {
          "name": "usuário autenticado com itens no carrinho"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer pact-token"
        },
        "method": "GET",
        "path": "/api/cart",
        "query": {
          "userId": [
            "9001"
          ]
        }
      },
      "response": {
        "body": [
          {
            "id": 101,
            "name": "Produto Pact 1",
            "price": 99.9,
            "product_id": 1,
            "quantity": 2
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].price": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            },
            "$[*].product_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].quantity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "uma requisição para listar produtos por categoria",
      "providerStates": [
        {
          "name": "catálogo com produtos disponíveis"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/products",
        "query": {
          "category": [
            "Eletrônicos"
          ]
        }
      },
      "response": {
        "body": [
          {
            "category": "Eletrônicos",
            "id": 1,
            "image": "https://example.com/pact.png",
            "name": "Produto Pact",
            "price": 199.9
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].category": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].image": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].price": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "tester-backend-api"
  }
}