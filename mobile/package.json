{
  "name": "amazonqa-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:debug": "expo run:android --variant debug",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --passWithNoTests",
    "test:api": "jest tests/integration/backend-connection.test.ts --runInBand",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:test:android:headless": "detox test --configuration android.emu.debug --headless"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tanstack/react-query": "^5.66.0",
    "axios": "^1.8.2",
    "expo": "~52.0.37",
    "expo-asset": "~11.0.5",
    "expo-font": "~13.0.4",
    "expo-localization": "~16.0.1",
    "expo-status-bar": "~2.0.1",
    "i18next": "^24.2.2",
    "react": "18.3.1",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.4.1",
    "react-native": "0.76.7",
    "react-native-paper": "^5.13.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "^18.3.1",
    "babel-preset-expo": "^12.0.2",
    "detox": "^20.50.1",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.4",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.7.3"
  }
}
